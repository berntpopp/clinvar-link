# clinvar-link configuration (copy to .env). All vars use the CLINVAR_LINK_ prefix.
# Nested config uses a double underscore, e.g. CLINVAR_LINK_DATA__DB_FILENAME.

# --- Server ---
# CLINVAR_LINK_HOST=127.0.0.1
# CLINVAR_LINK_PORT=8000
# CLINVAR_LINK_TRANSPORT=unified           # unified | http | stdio
# CLINVAR_LINK_LOG_LEVEL=INFO
# CLINVAR_LINK_LOG_FORMAT=console          # console | json
# CLINVAR_LINK_CORS_ORIGINS=*

# --- Local data store (bulk downloads -> SQLite index) ---
# CLINVAR_LINK_DATA__DATA_DIR=./data
# CLINVAR_LINK_DATA__DB_FILENAME=clinvar.db
# CLINVAR_LINK_DATA__AUTO_BOOTSTRAP=true    # build the DB on first start if absent
# CLINVAR_LINK_DATA__REFRESH_ENABLED=false  # cron owns refresh by default
# CLINVAR_LINK_DATA__REFRESH_INTERVAL_HOURS=24

# --- Live REST fallback (NCBI ClinVar / E-utilities) ---
# CLINVAR_LINK_API__CONTACT_EMAIL=you@example.org
# CLINVAR_LINK_API__TIMEOUT=30
# CLINVAR_LINK_API__ENABLE_LIVE_FALLBACK=true
