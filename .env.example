# clinvar-link configuration (copy to .env). All vars use the flat CLINVAR_LINK_ prefix.

# --- Server / MCP ---
# CLINVAR_LINK_MCP_TRANSPORT=unified        # unified | http
# CLINVAR_LINK_MCP_HOST=127.0.0.1
# CLINVAR_LINK_MCP_PORT=8000
# CLINVAR_LINK_MCP_PATH=/mcp
# CLINVAR_LINK_MCP_ALLOWED_HOSTS=["localhost","127.0.0.1","::1"]  # IPv6 is bare
# CLINVAR_LINK_MCP_ALLOWED_ORIGINS=[]  # admission gate; include every browser CORS origin
# CLINVAR_LINK_LOG_LEVEL=INFO
# CLINVAR_LINK_LOG_FORMAT=json              # json | console
# CLINVAR_LINK_CORS_ORIGINS=*
# CLINVAR_LINK_ENABLE_SWAGGER=true
# CLINVAR_LINK_ENABLE_MONITORING=true

# --- Local data store (ClinVar weekly bulk -> SQLite index) ---
# CLINVAR_LINK_DATA_DIR=./data
# CLINVAR_LINK_DB_FILENAME=clinvar.sqlite
# CLINVAR_LINK_SOURCE_URL=https://ftp.ncbi.nlm.nih.gov/pub/clinvar/tab_delimited/variant_summary.txt.gz
# CLINVAR_LINK_REFRESH_TTL_DAYS=7           # skip refresh if the index is younger than this
# CLINVAR_LINK_AUTO_BOOTSTRAP=false         # build the DB on first start if absent
# CLINVAR_LINK_ENABLE_SUBMISSION_SUMMARY=false  # optional submission_summary enrichment

# --- In-process cache / limits ---
# CLINVAR_LINK_CACHE_SIZE=1024
# CLINVAR_LINK_CACHE_TTL_MINUTES=60
# CLINVAR_LINK_MAX_PAGE_SIZE=100
