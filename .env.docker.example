# Example Docker environment for clinvar-link.
# Copy to .env.docker and edit for Compose deployments:
#
#   cp .env.docker.example .env.docker
#
# All keys are optional (the image and docker-compose.yml carry safe defaults).
# clinvar-link uses a flat CLINVAR_LINK_ prefix (no nested __ delimiters).

# ---- Local data store (prebuilt SQLite bundle from GitHub Releases) ----
# Where the installed SQLite index lives inside the container (mounted from the
# clinvar-data named volume).
CLINVAR_LINK_DATA_DIR=/app/data

# Bundle mode: on first boot `clinvar-link-data bootstrap` pulls the latest
# prebuilt clinvar.sqlite.zst from GitHub Releases, verifies its sha256,
# decompresses, and atomically installs it. Set BUILD_LOCAL=true to build from
# the NCBI bulk dump instead (heavy: ~414 MB gz / ~9 GB raw, several minutes).
CLINVAR_LINK_BUNDLE_URL=latest
CLINVAR_LINK_GITHUB_REPO=berntpopp/clinvar-link
CLINVAR_LINK_BUILD_LOCAL=false
# Staging dir for the downloaded .zst before decompression (an ephemeral tmpfs
# in docker-compose.yml).
CLINVAR_LINK_BUNDLE_DOWNLOAD_DIR=/tmp/clinvar-link

# ---- Server / MCP ----
CLINVAR_LINK_MCP_HOST=0.0.0.0
CLINVAR_LINK_MCP_PORT=8000

# ---- Logging ----
# Renderer for structlog: "json" in production, "console" in dev.
CLINVAR_LINK_LOG_FORMAT=json

# ---- Local published host port (docker-compose.yml) ----
# Container-internal port stays 8000; override the published host port here to
# avoid clashing with sibling *-link servers.
# CLINVAR_LINK_HOST_PORT=8000
