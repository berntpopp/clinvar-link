# Example Docker environment for clinvar-link.
# Copy to .env.docker and edit for Compose deployments:
#
#   cp .env.docker.example .env.docker
#
# All keys are optional (the image and docker-compose.yml carry safe defaults).
# clinvar-link uses a flat CLINVAR_LINK_ prefix (no nested __ delimiters).

# ---- Local data store (ClinVar weekly bulk -> SQLite index) ----
# Where the built SQLite index + cached bulk download live inside the container
# (mounted from the clinvar-data named volume).
CLINVAR_LINK_DATA_DIR=/app/data

# Build the index from the ClinVar bulk download on first start if it is absent
# (the entrypoint also auto-builds when the DB file is missing).
CLINVAR_LINK_AUTO_BOOTSTRAP=true

# ---- Server / MCP ----
CLINVAR_LINK_MCP_HOST=0.0.0.0
CLINVAR_LINK_MCP_PORT=8000

# ---- Logging ----
# Renderer for structlog: "json" in production, "console" in dev.
CLINVAR_LINK_LOG_FORMAT=json

# ---- Local published host port (docker-compose.yml) ----
# Container-internal port stays 8000; override the published host port here to
# avoid clashing with sibling *-link servers.
# CLINVAR_LINK_HOST_PORT=8000
